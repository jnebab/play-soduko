# ---- API ----
# Postgres in docker-compose; SQLite fallback used automatically if unset.
# DATABASE_URL=postgresql+asyncpg://sudoku:sudoku@localhost:5432/sudoku
DATABASE_URL=

# Redis for pub/sub fan-out + queue. If unset, an in-process bus is used (MVP single-process mode).
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# CORS origins for the web client (comma separated)
CORS_ORIGINS=http://localhost:5173

# Puzzle pool target size per difficulty (worker / startup fill)
POOL_TARGET=8

# ---- Web ----
# Base URL of the API for REST + WS (the web app derives ws:// from this)
VITE_API_URL=http://localhost:8000
